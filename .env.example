# ─────────────────────────────────────────────────────────────────────────────
# Instituto Job de Brito — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env!
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ijb_user:ijb_pass@localhost:5432/ijb

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use strings longas e aleatórias (mínimo 32 caracteres)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-string-at-least-32-chars

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mateus@institutojob.com.br
SMTP_PASS=your-smtp-password

# ─── E-mail Destinations ──────────────────────────────────────────────────────
EMAIL_CONTACT=mateus@institutojob.com.br
EMAIL_REVISTA=revista@institutojob.com.br

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=https://institutojob.com.br
